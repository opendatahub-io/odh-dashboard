{
  "extends": "@odh-dashboard/tsconfig/tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "baseUrl": "./src",
    "outDir": "./dist",
    "rootDirs": [
      "./src",
      "../base/types"
    ] /* overlays base/types/ onto src/ for virtual module type declarations */
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../base/src/**/*.ts",
    "../base/src/**/*.tsx",
    "../base/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "public"]
}
