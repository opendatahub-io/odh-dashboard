ARG BASE_IMAGE="registry.access.redhat.com/ubi9/nodejs-22@sha256:7e6fe0ffca449874cefe96f5c38a63aca52bdeda88a06ccff6ba3a0be60e19a8"

FROM ${BASE_IMAGE} AS builder

WORKDIR /usr/src/app

COPY --chown=default:root package.json package-lock.json ./

# All packages are needed for workspace resolution; plugin-core source
# is also needed at build time (webpack includes it in the transpile set).
COPY --chown=default:root packages/ ./packages/

# frontend/src (@odh-dashboard/internal) is needed at build time because
# plugin-core re-exports useResolvedExtensions which imports from it.
COPY --chown=default:root frontend/src/ ./frontend/src/

# Stub workspace roots that aren't needed for this build but must exist
# for npm ci to resolve the full workspace graph.
COPY --chown=default:root backend/package.json ./backend/package.json
COPY --chown=default:root frontend/package.json ./frontend/package.json

COPY --chown=default:root distributions/base/ ./distributions/base/

USER default

RUN npm cache clean --force
RUN npm ci --ignore-scripts

WORKDIR /usr/src/app/distributions/base
RUN npm run build

FROM ${BASE_IMAGE}

WORKDIR /usr/src/app

RUN mkdir /usr/src/app/logs && chmod 775 /usr/src/app/logs

USER 1001:0

COPY --chown=default:root --from=builder /usr/src/app/distributions/base/public ./public
COPY --chown=default:root --from=builder /usr/src/app/distributions/base/server ./server
COPY --chown=default:root --from=builder /usr/src/app/distributions/base/package.json ./package.json

EXPOSE 4000

CMD ["node", "server/stub.js"]

LABEL io.opendatahub.component="app-shell-base" \
      io.k8s.display-name="app-shell-base" \
      name="open-data-hub/app-shell-base-ubi9" \
      summary="app-shell-base" \
      description="Base app shell distribution for Open Data Hub Dashboard"
