    { "path": "./backend" },
    { "path": "./frontend" },
    { "path": "./packages/app-config" },
    { "path": "./packages/automl" },
    { "path": "./packages/autorag" },
    { "path": "./packages/contract-tests" },
    { "path": "./packages/cypress" },
    { "path": "./packages/eval-hub" },
    { "path": "./packages/feature-store" },
    { "path": "./packages/gen-ai" },
    { "path": "./packages/jest-config" },
    { "path": "./packages/kserve" },
    { "path": "./packages/llmd-serving" },
    { "path": "./packages/maas" },
    { "path": "./packages/mlflow-embedded" },
    { "path": "./packages/mlflow" },
    { "path": "./packages/model-registry" },
    { "path": "./packages/model-serving-backport" },
    { "path": "./packages/model-serving" },
    { "path": "./packages/model-training" },
    { "path": "./packages/notebooks" },
    { "path": "./packages/observability" },
    { "path": "./packages/plugin-core" },
    { "path": "./packages/plugin-template" },
    { "path": "./packages/tsconfig" }
  ]
}
