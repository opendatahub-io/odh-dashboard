{
  "name": "odh-dashboard-backend",
  "version": "2.0.0",
  "description": "Backend for the ODH dashboard.",
  "license": "Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opendatahub-io/odh-dashboard.git"
  },
  "homepage": "https://github.com/opendatahub-io/odh-dashboard#readme",
  "bugs": {
    "url": "https://github.com/opendatahub-io/odh-dashboard/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "src/server.ts",
  "scripts": {
    "clean": "rimraf ../logs/adminActivity.log",
    "start": "NODE_ENV=production IP=127.0.0.1 node ./dist/server.js",
    "start:dev": "npm run clean && cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=development nodemon src/server.ts",
    "debug": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=development nodemon --exec 'node --inspect --require ts-node/register' src/server.ts",
    "start:dev:wait": "wait-on -i 1000 http://localhost:4000",
    "build": "rimraf dist && tsc -p tsconfig.prod.json",
    "test": "run-s test:lint test:type-check test:jest",
    "test:unit-coverage": "npm run test:jest:coverage",
    "test:jest:coverage": "rimraf jest-coverage && jest --silent --coverage --coverageReporters=json --coverageReporters=lcov",
    "test:lint": "eslint --max-warnings 0 --ext .json,.js,.ts ./src",
    "test:fix": "eslint --ext .json,.js,.ts ./src --fix",
    "test:type-check": "turbo run type-check",
    "test:jest": "jest",
    "type-check": "tsc --noEmit",
    "server": "NODE_ENV=production node ./dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage"
  },
  "dependencies": {
    "@fastify/accepts": "^4.3.0",
    "@fastify/autoload": "^5.10.0",
    "@fastify/http-proxy": "^9.5.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^6.12.0",
    "@fastify/view": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "@kubernetes/client-node": "^0.12.3",
    "@odh-dashboard/app-config": "*",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",
    "http-errors": "^1.8.1",
    "js-yaml": "^4.2.0",
    "lodash": "^4.18.1",
    "pino": "^9.14.0",
    "tslib": "^2.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*",
    "@odh-dashboard/tsconfig": "*",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-barrel-files": "^1.3.1",
    "eslint-plugin-prettier": "^4.2.5",
    "@types/ejs": "^3.1.5",
    "@types/http-errors": "^1.8.2",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/ws": "^8.18.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^9.4.1",
    "prettier": "^2.8.8",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2"
  },
  "overrides": {
    "tough-cookie": "^4.1.4",
    "ws": "^8.21.0",
    "@types/tar": "^6.1.13",
    "jsonpath-plus": "^10.4.0"
  }
}
