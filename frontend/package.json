{
  "name": "odh-dashboard-frontend",
  "version": "2.0.0",
  "description": "Frontend for ODH dashboard.",
  "license": "Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opendatahub-io/odh-dashboard.git"
  },
  "homepage": "https://github.com/opendatahub-io/odh-dashboard#readme",
  "bugs": {
    "url": "https://github.com/opendatahub-io/odh-dashboard/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "run-s build:prod",
    "build:analyze": "run-s build build:bundle-profile build:bundle-analyze",
    "build:bundle-profile": "_ODH_OUTPUT_ONLY=true webpack --config ./config/webpack.prod.js --profile --json > ./bundle.stats.json",
    "build:bundle-analyze": "webpack-bundle-analyzer ./bundle.stats.json",
    "build:clean": "rimraf ./public",
    "build:prod": "webpack --config ./config/webpack.prod.js",
    "format": "prettier --write \"./**/*.ts\" \"./**/*.tsx\" \"./**/*.scss\"",
    "lint:goal": "eslint --config ./.eslintrc.goal.js --ext .json,.js,.ts,.jsx,.tsx ./src ",
    "start:dev": "webpack serve --hot --color --config ./config/webpack.dev.js",
    "start:dev:wait": "npx wait-on -i 1000 http://localhost:4010",
    "start:dev:mf": "cross-env MF_UPDATE_TYPES=true npm run start:dev",
    "start:dev:ext": "cross-env EXT_CLUSTER=true npm run start:dev",
    "test": "run-s test:lint test:type-check test:unit test:cypress-ci",
    "test:coverage": "run-s test:lint test:type-check test:jest:coverage test:cypress-ci:coverage coverage:merge",
    "test:fix": "eslint --ext .js,.ts,.jsx,.tsx . --fix",
    "test:lint": "eslint . && cd src && cross-env NODE_OPTIONS='--max-old-space-size=8192' eslint --max-warnings 0 --ext .js . && eslint --max-warnings 0 --ext .ts . && eslint --max-warnings 0 --ext .jsx,.tsx .",
    "test:type-check": "tsc --noEmit",
    "test:jest": "jest",
    "test:jest:coverage": "rimraf jest-coverage && jest --silent --coverage --coverageReporters=json --coverageReporters=lcov",
    "test-unit": "jest config/__tests__ --silent",
    "test:unit": "npm run test:jest -- --silent",
    "test:unit-coverage": "npm run test:jest:coverage",
    "test:cypress-ci": "npx concurrently -P -k -s first \"turbo run cypress:server:build --cwd=.. && turbo run cypress:server --cwd=..\" \"turbo run cypress:server:wait --cwd=.. && npm run cypress:run:mock -- {@}\" -- ",
    "test:cypress-ci:coverage": "npx concurrently -P -k -s first \"turbo run cypress:server:build:coverage --cwd=.. && turbo run cypress:server --cwd=..\" \"turbo run cypress:server:wait --cwd=.. && npm run cypress:run:mock:coverage -- {@}\" -- ",
    "test:cypress-ci:coverage:nobuild": "npx concurrently -P -k -s first 'turbo run cypress:server --cwd=..' 'turbo run cypress:server:wait --cwd=.. && npm run cypress:run:mock:coverage -- {@}' --",
    "coverage:merge": "rimraf coverage && istanbul-merge --out coverage/coverage-final.json jest-coverage/coverage-final.json ../packages/cypress/coverage/coverage-final.json && nyc report --reporter html -t coverage --report-dir coverage/report && nyc report --reporter json-summary -t coverage --report-dir coverage",
    "cypress:open": "cypress open --project ../packages/cypress",
    "cypress:e2e": "npx cypress run --env grepTags=@Dashboard+-@Bug --browser=chrome --project ../packages/cypress",
    "cypress:run": "cypress run -b chrome --project ../packages/cypress",
    "cypress:open:mock": "cross-env CY_MOCK=1 CY_WS_PORT=9002 npm run cypress:open -- ",
    "cypress:run:mock": "cross-env CY_MOCK=1 CY_WS_PORT=9002 npm run cypress:run -- ",
    "cypress:run:mock:coverage": "rimraf ../packages/cypress/coverage ../packages/cypress/.nyc_output && cross-env CY_COVERAGE=true npm run cypress:run:mock -- {@}",
    "cypress:open:record": "cross-env CY_RECORD=1 npm run cypress:open",
    "cypress:run:electron": "cypress run -b electron --project ../packages/cypress",
    "cypress:run:chrome": "cypress run -b chrome --project ../packages/cypress",
    "cypress:run:record": "cross-env CY_RECORD=1 npm run cypress:run && npm run cypress:format",
    "cypress:server:build": "cross-env MF_DEV=true ODH_DIST_DIR=./public-cypress POLL_INTERVAL=9999999 FAST_POLL_INTERVAL=9999999 WS_HOSTNAME=localhost:9002 npm run build",
    "cypress:server:build:coverage": "cross-env COVERAGE=true npm run cypress:server:build",
    "cypress:server": "serve ./public-cypress -p 9001 -s -L",
    "cypress:server:dev": "cross-env POLL_INTERVAL=9999999 FAST_POLL_INTERVAL=9999999 ODH_PORT=9001 WS_HOSTNAME=localhost:9002 npm run start:dev",
    "cypress:format": "prettier --write ../packages/cypress/cypress/**/*.snap.json",
    "test:cypress:e2e": "npx cypress run --project ../packages/cypress --env grepTags=\"${CY_TEST_TAGS}\",skipTags=\"${CY_SKIP_TAGS}\" --browser chrome",
    "test:cypress:e2e:open": "npx cypress open --project ../packages/cypress --env grepTags=\"${CY_TEST_TAGS}\",skipTags=\"${CY_SKIP_TAGS}\"",
    "cypress:server:wait": "npx wait-on -i 1000 http://localhost:9001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
