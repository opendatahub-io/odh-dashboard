{
  "name": "@odh-dashboard/internal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage"
  },
  "imports": {
    "#~/*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "exports": {
    "./extensions": "./plugins/extensions/index.ts",
    "./app/AppContext": "./app/AppContext.ts",
    "./app/AppLauncher": "./app/AppLauncher.tsx",
    "./app/ThemeContext": "./app/ThemeContext.tsx",
    "./app/*": null,
    "./plugin/*": null,
    "./third_party/*": null,
    "./*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "dependencies": {
    "@module-federation/runtime": "^0.24.1",
    "@odh-dashboard/app-config": "*",
    "@odh-dashboard/plugin-core": "*",
    "@segment/analytics-next": "^1.84.0",
    "@types/dompurify": "^3.2.0",
    "axios": "^1.16.1",
    "dompurify": "^3.4.5",
    "monaco-editor": "^0.55.1",
    "react-dropzone": "^14.4.1",
    "react-router": "^7.15.1",
    "react-router-dom": "^7.15.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*"
  },
  "optionalDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/cypress": "^10.1.3",
    "cypress": "^15.15.0",
    "cypress-mochawesome-reporter": "^3.8.4",
    "serve": "^14.2.6",
    "ts-jest": "^29.4.11"
  }
}
