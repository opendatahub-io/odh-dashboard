{
  "name": "@odh-dashboard/internal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage"
  },
  "imports": {
    "#~/*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "exports": {
    "./extensions": "./plugins/extensions/index.ts",
    "./app/AppContext": "./app/AppContext.ts",
    "./app/AppLauncher": "./app/AppLauncher.tsx",
    "./app/ThemeContext": "./app/ThemeContext.tsx",
    "./app/*": null,
    "./plugin/*": null,
    "./third_party/*": null,
    "./*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@odh-dashboard/app-config": "*",
    "@odh-dashboard/plugin-core": "*",
    "@segment/analytics-next": "^1.84.0",
    "@swc/core": "^1.15.40",
    "@types/react": "^18.3.29",
    "axios": "^1.16.1",
    "core-js": "^3.49.0",
    "dompurify": "^3.4.6",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "protobufjs": "^7.6.1",
    "react-dropzone": "^14.4.1",
    "sass": "^1.100.0",
    "slnodejs": "^6.2.18",
    "speed-measure-webpack-plugin": "^1.6.0",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.6.0",
    "webpack-dev-server": "^5.2.4",
    "yaml": "^2.9.0",
    "yaml-eslint-parser": "^1.3.2"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*"
  },
  "optionalDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/cypress": "^10.1.3",
    "cypress": "^15.16.0",
    "serve": "^14.2.6",
    "ts-jest": "^29.4.11"
  }
}
