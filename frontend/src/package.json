{
  "name": "@odh-dashboard/internal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage"
  },
  "imports": {
    "#~/*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "exports": {
    "./extensions": "./plugins/extensions/index.ts",
    "./app/AppContext": "./app/AppContext.ts",
    "./app/AppLauncher": "./app/AppLauncher.tsx",
    "./app/ThemeContext": "./app/ThemeContext.tsx",
    "./app/*": null,
    "./plugin/*": null,
    "./third_party/*": null,
    "./*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "dependencies": {
    "@odh-dashboard/app-config": "*",
    "@odh-dashboard/plugin-core": "*",
    "@patternfly/react-charts": "^8.4.1",
    "@patternfly/react-code-editor": "^6.4.3",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-drag-drop": "^6.4.3",
    "@patternfly/react-table": "^6.4.3",
    "@patternfly/react-templates": "^6.4.3"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*"
  }
}
