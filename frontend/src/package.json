{
  "name": "@odh-dashboard/internal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage"
  },
  "imports": {
    "#~/*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "exports": {
    "./extensions": "./plugins/extensions/index.ts",
    "./app/AppContext": "./app/AppContext.ts",
    "./app/AppLauncher": "./app/AppLauncher.tsx",
    "./app/ThemeContext": "./app/ThemeContext.tsx",
    "./app/*": null,
    "./plugin/*": null,
    "./third_party/*": null,
    "./*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "dependencies": {
    "@babel/core": "^7.28.6",
    "@odh-dashboard/app-config": "*",
    "@odh-dashboard/plugin-core": "*",
    "@segment/analytics-next": "^1.81.2",
    "@swc/core": "^1.13.21",
    "axios": "^1.15.2",
    "html-webpack-plugin": "^5.6.7",
    "protobufjs": "^7.5.7",
    "react-dropzone": "^14.3.8",
    "react-router-dom": "^7.9.6",
    "sass": "^1.93.3",
    "slnodejs": "^6.1.1163",
    "swc-loader": "^0.2.7",
    "yaml": "^2.8.4",
    "yaml-eslint-parser": "^1.3.2"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*"
  },
  "optionalDependencies": {
    "@babel/preset-env": "^7.28.6",
    "@testing-library/cypress": "^10.1.3",
    "cypress-mochawesome-reporter": "^3.8.4",
    "serve": "^14.2.6",
    "ts-jest": "^29.4.9"
  }
}
