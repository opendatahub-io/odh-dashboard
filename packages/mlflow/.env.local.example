# This file serves as an example environment configuration for local development.
# Copy this file to `.env.local` (not committed) and modify the values as needed.

# Application Environment
APP_ENV=local

# Deployment mode (standalone or federated)
DEPLOYMENT_MODE=standalone

# MLflow tracking server URL - point to your local or remote MLflow instance
MLFLOW_URL=https://localhost:8443

# Skip TLS certificate verification (useful for development with self-signed certs)
INSECURE_SKIP_VERIFY=true
