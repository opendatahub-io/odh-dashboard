{
  "private": true,
  "name": "@odh-dashboard/gen-ai",
  "description": "Gen AI plugin.",
  "version": "0.0.0",
  "module-federation": {
    "name": "genAi",
    "remoteEntry": "/remoteEntry.js",
    "authorize": true,
    "tls": false,
    "proxy": [
      {
        "path": "/gen-ai/api",
        "pathRewrite": "/api"
      }
    ],
    "local": {
      "host": "localhost",
      "port": 9102
    },
    "service": {
      "name": "odh-dashboard",
      "port": 8043
    }
  },
  "e2eCiTags": ["@GenAICI"],
  "scripts": {
    "install:module": "npm install --prefix frontend",
    "test:contract": "cross-env BFF_MOCK_FLAGS='--mock-k8s-client --mock-ls-client --mock-mcp-client --mock-mlflow-client --mock-bff-clients' odh-ct-bff-consumer --bff-dir bff",
    "cypress:server:build": "cd frontend && cross-env DIST_DIR=./public-cypress DEPLOYMENT_MODE=federated npm run build",
    "cypress:server:build:coverage": "cross-env COVERAGE=true npm run cypress:server:build",
    "cypress:server": "cd frontend && serve ./public-cypress -p 9102 -s -L",
    "cypress:server:dev": "cd frontend && cross-env DEPLOYMENT_MODE=federated PORT=9102 PROXY_PORT=8080 npm run start:dev",
    "cypress:server:wait": "wait-on -i 1000 http-get://localhost:9102/healthcheck",
    "cypress:server:e2e:wait": "npm run cypress:server:wait",
    "prepare:e2e": "cd bff && go mod download",
    "cypress:server:e2e": "STATIC_ASSETS_DIR=../frontend/public-cypress make dev-bff-e2e-cluster E2E_BFF_PORT=9102",
    "lint": "cd frontend && npm run lint",
    "lint:fix": "cd frontend && npm run lint:fix"
  },
  "exports": {
    "./extension-points": "./frontend/src/odh/extension-points/index.ts",
    "./types": "./frontend/src/types/index.ts"
  },
  "dependencies": {
    "@odh-dashboard/internal": "*",
    "@odh-dashboard/k8s-core": "*",
    "@odh-dashboard/plugin-core": "*",
    "@odh-dashboard/ui-core": "*"
  },
  "devDependencies": {
    "@odh-dashboard/contract-tests": "*",
    "@odh-dashboard/eslint-config": "*",
    "@odh-dashboard/tsconfig": "*"
  }
}
