# This file serves as an example environment configuration for local development.
# Copy this file to `.env.local` (not committed) and modify the values as needed.

# Application Environment
APP_ENV=local

# Deployment mode (standalone or integrated)
DEPLOYMENT_MODE=standalone

# LlamaStack API URL - point to your local or remote LlamaStack instance
LLAMA_STACK_URL=http://localhost:8321

# MaaS endpoint – provide either the Kuadrant MaaS Gateway URL or direct MaaS Service URL
# For HTTP use http:// with MAAS_SERVICE_PORT=8080 (default), 
# For HTTPS use https:// with INSECURE_SKIP_VERIFY=true & MAAS_SERVICE_PORT=8443 (requires TLS setup for maas, it's default with maas installed via /models-as-a-service/scripts/deploy.sh)
MAAS_URL=http://localhost:8081
MAAS_SERVICE_PORT=8080
# Local port used by `make dev-portforward` for the maas-api port-forward (must match MAAS_URL port)
MAAS_LOCAL_PORT=8081

# Skip TLS certificate verification - set to true when using TLS backend via port-forward
INSECURE_SKIP_VERIFY=false

# MLflow tracking server URL
MLFLOW_URL=https://localhost:8443

# Docker distribution name for LlamaStack
DISTRIBUTION_NAME=quay.io/opendatahub/llama-stack:latest

# This should be the k8s namespace where "maas-api" service is deployed in cluster you are using (used in port-forwarding)
MAAS_NAMESPACE=maas-api

# This should be the k8s namespace where "lsd-genai-playground-service" service is deployed in cluster you are using (used in port-forwarding)
# PLAYGROUND_NAMESPACE=default
PLAYGROUND_NAMESPACE=crimson-dev

# This should be the k8s namespace where the MLflow service is deployed (used in port-forwarding)
MLFLOW_NAMESPACE=opendatahub

# OTel tracing — set to enable BFF span export to the platform collector
# Requires port-forward: oc port-forward svc/data-science-collector-collector -n opendatahub 4318:4318
# Leave commented out to disable tracing (opt-in)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# OTel collector CR — the BFF auto-discovers the platform OpenTelemetryCollector CR
# at startup by listing CRs across all namespaces. Set these to override auto-discovery.
# OTEL_COLLECTOR_NAMESPACE=opendatahub          # RHOAI: redhat-ods-monitoring, ODH: opendatahub
# OTEL_COLLECTOR_NAME=data-science-collector    # default; rarely needs changing
