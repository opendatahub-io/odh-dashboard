# This file serves as an example environment configuration for local development.
# Copy this file to `.env.local` (not committed) and modify the values as needed.

# Application Environment
APP_ENV=local

# Deployment mode (standalone or integrated)
DEPLOYMENT_MODE=standalone

# LlamaStack API URL - point to your local or remote LlamaStack instance
LLAMA_STACK_URL=http://localhost:8321

# MaaS endpoint – provide the Kuadrant MaaS Gateway URL or direct MaaS Service URL.
# Used by `make dev-start-maas` (passed to MaaS BFF as MAAS_API_URL) and as the
# gen-ai BFF's guardrail availability gate.
# For HTTPS (Kuadrant gateway, default for RHOAI): set INSECURE_SKIP_VERIFY=true
# For HTTP (direct maas-api via port-forward): use http:// with INSECURE_SKIP_VERIFY=false
MAAS_URL=https://maas.apps.<your-cluster-domain>/maas-api

# Skip TLS certificate verification — ONLY set to true for local dev clusters
# with self-signed certificates. Never enable in production.
INSECURE_SKIP_VERIFY=false

# MLflow tracking server URL
MLFLOW_URL=https://localhost:8443

# Docker distribution name for LlamaStack
DISTRIBUTION_NAME=quay.io/opendatahub/llama-stack:latest

# This should be the k8s namespace where "lsd-genai-playground-service" service is deployed in cluster you are using (used in port-forwarding)
# PLAYGROUND_NAMESPACE=default
PLAYGROUND_NAMESPACE=crimson-dev

# This should be the k8s namespace where the MLflow service is deployed (used in port-forwarding)
MLFLOW_NAMESPACE=opendatahub

# ASR model endpoint for local development (Whisper/audio-transcription model)
# KServe InferenceServices use headless services that don't work with `oc port-forward svc/`.
# Create a regular ClusterIP Service in your namespace that selects the ASR model pods
# (selector: app: isvc.<model-name>-predictor) and exposes port 8080.
# Then set ASR_SERVICE_NAME to that proxy service name.
# ASR_MODEL_URL=http://localhost:8790

# ASR proxy service name for automatic port-forwarding via `make dev-portforward`
# ASR_SERVICE_NAME=<your-proxy-service-name>
# ASR_LOCAL_PORT=8790
