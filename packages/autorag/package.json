{
  "private": true,
  "name": "@odh-dashboard/autorag",
  "description": "AutoRAG plugin.",
  "version": "0.0.0",
  "module-federation": {
    "name": "autorag",
    "remoteEntry": "/remoteEntry.js",
    "authorize": true,
    "tls": false,
    "proxy": [
      {
        "path": "/autorag/api",
        "pathRewrite": "/api"
      }
    ],
    "local": {
      "host": "localhost",
      "port": 9107
    },
    "service": {
      "name": "odh-dashboard",
      "port": 8043
    }
  },
  "e2eCiTags": ["@AutoRAGCI"],
  "bffConfig": {
    "enabled": true,
    "port": 4001,
    "healthEndpoint": "/healthcheck",
    "startCommand": "make dev-bff-e2e-mock",
    "startCommandCluster": "make dev-bff-e2e-cluster"
  },
  "scripts": {
    "install:module": "npm install --prefix frontend",
    "test:contract": "BFF_MOCK_FLAGS='--dev-mode --mock-k8s-client --mock-ogx-client --mock-http-client --mock-pipeline-server-client --mock-s3-client --deployment-mode=standalone --auth-method=internal' odh-ct-bff-consumer --bff-dir bff",
    "cypress:server:build": "cd frontend && DIST_DIR=./public-cypress DEPLOYMENT_MODE=federated npm run build",
    "cypress:server:build:coverage": "COVERAGE=true npm run cypress:server:build",
    "cypress:server": "cd frontend && serve ./public-cypress -p 9107 -s -L",
    "cypress:server:dev": "cd frontend && DEPLOYMENT_MODE=federated PORT=9107 PROXY_PORT=4001 npm run start:dev",
    "cypress:server:wait": "wait-on -i 1000 http://localhost:9107",
    "lint": "cd frontend && npm run lint",
    "lint:fix": "cd frontend && npm run lint:fix"
  },
  "dependencies": {
    "@odh-dashboard/internal": "*",
    "@odh-dashboard/k8s-core": "*",
    "@odh-dashboard/plugin-core": "*",
    "@odh-dashboard/ui-core": "*"
  },
  "devDependencies": {
    "@odh-dashboard/contract-tests": "*",
    "@odh-dashboard/eslint-config": "*",
    "@odh-dashboard/tsconfig": "*"
  }
}
