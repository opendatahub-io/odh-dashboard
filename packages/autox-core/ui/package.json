{
  "name": "autox-frontend",
  "version": "0.0.0",
  "description": "AutoX frontend shared library",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "run-s test:lint test:type-check test:unit",
    "test:jest": "jest",
    "test:unit": "npm run test:jest -- --silent",
    "test:fix": "eslint --ext .js,.ts,.jsx,.tsx ./src ./*.js --fix && prettier --write ./*.js ./*.cjs ./*.md ../*.md",
    "lint": "eslint --max-warnings 0 --ext .js,.ts,.jsx,.tsx ./src ./*.js",
    "lint:fix": "eslint --ext .js,.ts,.jsx,.tsx ./src ./*.js --fix",
    "test:lint": "eslint --max-warnings 0 --ext .js,.ts,.jsx,.tsx ./src ./*.js && prettier --check ./*.js ./*.cjs ./*.md ../*.md",
    "test:type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.8",
    "@types/react-dom": "^18.3.1",
    "expect": "^30.0.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.3.3",
    "tslib": "^2.7.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@patternfly/patternfly": "^6.3.1",
    "@patternfly/react-component-groups": "^6.4.0",
    "@patternfly/react-core": "^6.3.1",
    "@patternfly/react-icons": "^6.3.1",
    "@patternfly/react-styles": "^6.3.1",
    "@patternfly/react-table": "^6.3.1",
    "@patternfly/react-templates": "^6.3.1",
    "@patternfly/react-topology": "^6.4.0",
    "@tanstack/react-query": "^5.90.20",
    "classnames": "^2.2.6",
    "es-toolkit": "^1.44.0",
    "lodash-es": "^4.17.15",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.5.2",
    "react-router-dom": "^7.6.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "@tanstack/react-query": "^5.90.20"
  }
}
