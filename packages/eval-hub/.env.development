APP_ENV=development
DEPLOYMENT_MODE=standalone
EVAL_HUB_URL=http://localhost:8080
EVAL_HUB_NAMESPACE=evalhub-test
EVAL_HUB_SVC_NAME=evalhub
EVAL_HUB_LOCAL_PORT=8080
EVAL_HUB_SVC_PORT=8080

# ─── Inter-BFF Communication ─────────────────────────────────
# Enable/disable mock BFF clients (true = use mocks, false = call real BFFs)
# MOCK_BFF_CLIENTS=true

# Model-Catalog BFF service configuration (for inter-BFF security artifact requests)
# BFF_MODEL_CATALOG_SERVICE_NAME=odh-dashboard
# BFF_MODEL_CATALOG_SERVICE_PORT=8043
# BFF_MODEL_CATALOG_TLS_ENABLED=false
# BFF_MODEL_CATALOG_DEV_URL=http://localhost:4000/api/v1

# Model-Catalog BFF auth configuration
# BFF_MODEL_CATALOG_AUTH_METHOD=user_token
# BFF_MODEL_CATALOG_AUTH_TOKEN_HEADER=x-forwarded-access-token
# BFF_MODEL_CATALOG_AUTH_TOKEN_PREFIX=
