{
  "private": true,
  "name": "@odh-dashboard/automl",
  "description": "AutoML plugin.",
  "version": "0.0.0",
  "module-federation": {
    "name": "automl",
    "remoteEntry": "/remoteEntry.js",
    "authorize": true,
    "tls": false,
    "proxy": [
      {
        "path": "/automl/api",
        "pathRewrite": "/api"
      }
    ],
    "local": {
      "host": "localhost",
      "port": 9108
    },
    "service": {
      "name": "odh-dashboard",
      "port": 8043
    }
  },
  "cypress": {
    "mocked": "frontend/src/__tests__/cypress/cypress/tests/mocked/**/*.cy.ts"
  },
  "e2eCiTags": ["@AutoMLCI"],
  "bffConfig": {
    "enabled": true,
    "port": 4003,
    "healthEndpoint": "/healthcheck",
    "startCommand": "make dev-bff-e2e-mock",
    "startCommandCluster": "make dev-bff-e2e-cluster"
  },
  "scripts": {
    "install:module": "npm install --prefix frontend",
    "test:contract": "BFF_MOCK_FLAGS='--dev-mode --mock-k8s-client --mock-http-client --mock-s3-client --mock-pipeline-server-client --deployment-mode=standalone --auth-method=internal' odh-ct-bff-consumer --bff-dir bff",
    "cypress:server:build": "cd frontend && DIST_DIR=./public-cypress DEPLOYMENT_MODE=federated npm run build",
    "cypress:server:build:coverage": "COVERAGE=true npm run cypress:server:build",
    "cypress:server": "cd frontend && serve ./public-cypress -p 9108 -s -L",
    "cypress:server:dev": "cd frontend && DEPLOYMENT_MODE=federated PORT=9108 PROXY_PORT=4003 npm run start:dev",
    "cypress:server:wait": "npx wait-on -i 1000 http://localhost:9108",
    "lint": "cd frontend && npm run lint",
    "lint:fix": "cd frontend && npm run lint:fix"
  },
  "dependencies": {
    "@odh-dashboard/internal": "*",
    "@odh-dashboard/plugin-core": "*"
  },
  "devDependencies": {
    "@odh-dashboard/contract-tests": "*",
    "@odh-dashboard/eslint-config": "*",
    "@odh-dashboard/tsconfig": "*",
    "eslint-plugin-n": "^17.23.1"
  }
}
